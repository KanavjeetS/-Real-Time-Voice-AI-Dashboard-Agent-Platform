# Copy to .env and fill in — NEVER commit .env

MODEL_TIER=free
STARTUP_WARM_MODELS=true

GROQ_API_KEY=
GROQ_LLM_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_INTENT_MODEL=llama-3.1-8b-instant
GROQ_STT_MODEL=whisper-large-v3
GROQ_STT_LANGUAGE=
DEEPGRAM_API_KEY=
ENABLE_STREAMING_STT=true
STT_STREAM_ENDPOINTING_MS=250

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Production: your Railway/Render public URL (no trailing slash)
TWILIO_WEBHOOK_BASE_URL=https://your-api.up.railway.app

DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/postgres
USE_DATABASE=true

REDIS_URL=redis://default:password@host:6379/0

SLACK_WEBHOOK_URL=

APP_ENV=development
LOG_LEVEL=INFO
# JSON array — include your Vercel URL in production
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

MAX_CONCURRENT_CALLS=10
CALL_TIMEOUT_SECONDS=300
DEFAULT_PHONE_REGION=IN
